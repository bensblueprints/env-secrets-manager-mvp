# Secretbox configuration — copy to .env and edit

# Port the web app listens on
PORT=5345

# Admin password for the web UI (change this!)
ADMIN_PASSWORD=change-me

# Envelope-encryption master key: 64 hex chars (32 bytes).
# Lives ONLY here on the host — never in the database. BACK IT UP:
# without it, your secrets are unrecoverable.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=

# SQLite database location (stores ciphertext + wrapped DEKs only)
DB_PATH=./data/secretbox.db
